# ── Web simulator (demo-web/harmonic-demo) ────────────────────────────────────
# Frontend puro — nenhuma variável é obrigatória.
PORT=3000

# ── Fastify API server (server/) ──────────────────────────────────────────────
# Porta do servidor de API (separado do Next.js)
API_PORT=3001

# Conexão com PostgreSQL (obrigatória para o server/)
DATABASE_URL=postgresql://harmonic:harmonic@localhost:5432/harmonic_iot

# Redis (opcional — profile db do docker-compose.production.yml)
REDIS_URL=redis://:harmonic_redis_pass@localhost:6379

# CORS — origens permitidas para o servidor de API
CORS_ORIGIN=http://localhost:3000

# ── Autenticação JWT (server/src/security) ────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string-in-production
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ENCRYPTION_KEY=change-me-to-32-chars-exactly!!!

# ── PostgreSQL (docker-compose --profile db) ──────────────────────────────────
POSTGRES_DB=harmonic_iot
POSTGRES_USER=harmonic
POSTGRES_PASSWORD=harmonic

# ── Redis (docker-compose --profile db) ──────────────────────────────────────
REDIS_PASSWORD=harmonic_redis_pass

# ── Observabilidade (docker-compose --profile observability) ──────────────────
GRAFANA_PASSWORD=admin

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
